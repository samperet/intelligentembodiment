# ─────────────────────────────────────────────────────────────────────────────
# Intelligent Embodiment — environment configuration
# Copy this file to `.env.local` for local dev, and add the same variables in
# Vercel → Project → Settings → Environment Variables for production.
# ─────────────────────────────────────────────────────────────────────────────

# The public URL of the site (used in emails / confirmations).
NEXT_PUBLIC_SITE_URL=https://intelligentembodiment.com

# ── Google Calendar sync (service account) ───────────────────────────────────
# 1. Create a Google Cloud project → enable the "Google Calendar API".
# 2. Create a Service Account, then a JSON key for it.
# 3. In Google Calendar, share Mackensie's calendar with the service account
#    email ("Make changes to events" permission).
# 4. Paste the values below.
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the full private key. Keep the literal \n escapes on one line, e.g.
# "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# The calendar to write bookings to. Use "primary" or the calendar's ID
# (looks like an email address, found in Calendar Settings → Integrate calendar).
GOOGLE_CALENDAR_ID=mackensie11@gmail.com

# ── Business owner (receives a copy / notifications) ─────────────────────────
OWNER_EMAIL=mackensie11@gmail.com

# ── Optional: transactional email confirmations via Resend (resend.com) ──────
# If unset, the site still books to the calendar and Google emails the invite.
RESEND_API_KEY=
# The "from" address must be on a domain you've verified in Resend.
EMAIL_FROM=Intelligent Embodiment <hello@intelligentembodiment.com>

# ── Optional: Cloudflare R2 public asset host (for images) ───────────────────
# e.g. https://pub-xxxx.r2.dev  — referenced by NEXT_PUBLIC_ASSET_HOST in code.
NEXT_PUBLIC_ASSET_HOST=
